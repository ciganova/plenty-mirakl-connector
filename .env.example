# === Mirakl Douglas Configuration ===
MIRAKL_BASE_URL=https://your-shop.mirakl.net
MIRAKL_API_KEY=your-mirakl-api-key-here
MIRAKL_SHOP_ID=12345

# === PlentyONE Configuration ===
PLENTY_BASE_URL=https://your-shop.plentymarkets.com
PLENTY_USERNAME=your-plenty-api-user
PLENTY_PASSWORD=your-plenty-api-password
PLENTY_REFERRER_ID=1
PLENTY_WAREHOUSE_ID=1
PLENTY_PLENTY_ID=12345

# === Database ===
DATABASE_URL=postgresql+asyncpg://connector:secret@postgres:5432/connector

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Application ===
DRY_RUN=false
LOG_LEVEL=INFO
# Polling intervals in seconds
ORDER_POLL_INTERVAL=300
TRACKING_POLL_INTERVAL=900

# === Traefik ===
TRAEFIK_DOMAIN=connector.domain.de
